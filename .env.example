NODE_ENV=development
PORT=3000

ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

WHATSAPP_ACCESS_TOKEN=your-whatsapp-cloud-api-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=choose-a-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_API_VERSION=v21.0

CRM_BASE_URL=https://whatsapp-automation.fly.dev
# CRM_API_KEY es el "token de integración" generado por el superadmin del CRM vía
# POST /api/superadmin/companies/{id}/integration-token (un JWT de larga duración con
# el companyId de esta empresa embebido), no una API key arbitraria.
CRM_API_KEY=your-crm-integration-token
