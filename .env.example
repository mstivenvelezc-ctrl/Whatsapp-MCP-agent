NODE_ENV=development
PORT=3000

ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# INTERNAL_AGENT_SECRET protege POST /internal/respond, el único endpoint que expone este
# servicio. Lo llama el CRM Java (AiAgentBridgeService) cuando una empresa Premium/Custom
# activa el toggle "Agente IA", pasando en cada request el companyId y el token de
# integración de esa empresa (ya no hay credenciales fijas de WhatsApp ni de CRM aquí:
# el agente es multi-tenant). Debe tener exactamente el mismo valor que
# AI_AGENT_INTERNAL_SECRET en el backend Java.
INTERNAL_AGENT_SECRET=choose-a-long-random-shared-secret
