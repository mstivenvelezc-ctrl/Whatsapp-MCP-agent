NODE_ENV=development
PORT=3000

# Nombre del modelo por defecto para cada proveedor. La API key de cada empresa NO vive
# aquí: la trae cada empresa (Claude/OpenAI/Gemini) y llega por request desde el CRM Java
# (AiAgentBridgeService), junto con el companyId y el token de integración de esa empresa.
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash

# INTERNAL_AGENT_SECRET protege POST /internal/respond, el único endpoint que expone este
# servicio. Lo llama el CRM Java (AiAgentBridgeService) cuando una empresa Premium/Custom
# activa el toggle "Agente IA". Debe tener exactamente el mismo valor que
# AI_AGENT_INTERNAL_SECRET en el backend Java.
INTERNAL_AGENT_SECRET=choose-a-long-random-shared-secret
